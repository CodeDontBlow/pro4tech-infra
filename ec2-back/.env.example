# ─── Aplicação ───────────────────────────────────────────────
PORT=3333

# ─── PostgreSQL ──────────────────────────────────────────────
# Aponta para a ec2-db (IP privado), não localhost
POSTGRES_USER=pro4tech
POSTGRES_PASSWORD=          # ← mesma senha do .env da ec2-db
POSTGRES_DB=pro4tech
POSTGRES_HOST=<IP-PRIVADO-EC2-DB>
POSTGRES_PORT=5432

# ─── Prisma ──────────────────────────────────────────────────
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@<IP-PRIVADO-EC2-DB>:5432/${POSTGRES_DB}?schema=public"

# ─── MongoDB ─────────────────────────────────────────────────
MONGO_URI="mongodb://<IP-PRIVADO-EC2-DB>:27017/orbita-chat"

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=jwt_secret_para_prod

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGIN=https://web.orbita4tech.hopto.org,https://orbita4tech.hopto.org

# ─── MinIO ───────────────────────────────────────────────────
MINIO_ENDPOINT=<IP-PRIVADO-EC2-DB>
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=            # ← mesmo valor do .env da ec2-db
MINIO_SECRET_KEY=            # ← mesmo valor do .env da ec2-db
MINIO_BUCKET=pro4tech
MINIO_PUBLIC_URL=http://<IP-PRIVADO-EC2-DB>:9000
MINIO_SET_PUBLIC=true

# ─── Upload limits (MB) ──────────────────────────────────────
CHAT_UPLOAD_MAX_MB=10
AVATAR_UPLOAD_MAX_MB=5
LOGO_UPLOAD_MAX_MB=5

# ─── Rate limiting ────────────────────────────────────────────
TICKET_CREATE_RATE_LIMIT_MAX=3
TICKET_CREATE_RATE_LIMIT_WINDOW_MS=60000